# ─── Base de données (Railway PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/scrivia?schema=public"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# En dev : http://localhost:3000  |  En prod : https://votre-domaine.vercel.app
NEXTAUTH_URL="http://localhost:3000"
# Générer avec : openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# https://console.cloud.google.com/ → OAuth 2.0 → Credentials
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── Anthropic (Claude AI) ────────────────────────────────────────────────────
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY="sk-ant-..."

# ─── Cloudinary ───────────────────────────────────────────────────────────────
# https://console.cloudinary.com/ → Settings → API Keys
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ─── Maketou (paiement Mobile Money) ─────────────────────────────────────────
MAKETOU_API_KEY="your-maketou-api-key"
MAKETOU_SECRET="your-maketou-webhook-secret"
# URL de base de l'API Maketou (à confirmer avec leur doc)
MAKETOU_BASE_URL="https://api.maketou.com/v1"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
